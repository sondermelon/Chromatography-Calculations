#AOV Analysis

#Formatting Column Names
colnames(df) <- make.names(colnames(df))

#Running One-Way ANOVA
LP <- aov(L.Phenylalanine ~ Scion.Cultivar, data = df)
summary(LP)

#Post-Hoc Tukey HSD and Mean Letter Grouping
LPTukey <- TukeyHSD(LP)
LPGrouping <- multcompLetters4(LP, LPTukey)
LPGrouping

#Determine Mean Value
LPMeans <- aggregate(L.Phenylalanine ~ Scion.Cultivar, data = df, mean)

#Create Table for Amino Acid sorted by Highest to Lowest mg/L
letters_LPC <- c(
     "Star Ruby" = "a",
     "Hamilin" = "ab",
     "Early Pride" = "abc",
     "Alsop" = "bcd",
     "Cara Cara" = "bcd",
     "Bahia" = "bcd",
     "Glen" = "cd",
     "Early Gold" = "d",
     "1.4.59" = "d",
     "Tresca" = "d")
 
LPCLetters_df <- data.frame(Scion.Cultivar = names(letters_LPC), Letters = letters_LPC)
LPTable <- merge(LPMeans, LPCLetters_df, by = "Scion.Cultivar")
LPTable <- LPTable[order(-LPTable$L.Phenylalanine), ]
LPTable
