# Create VIP Chart
# Calculate and sort VIP scores
vip_comp1 <- vip(final_plsda)[, 1]
top_vips  <- sort(vip_comp1, decreasing = TRUE)[1:10]
vip_df <- data.frame(
Metabolite = factor(names(top_vips), levels = rev(names(top_vips))),
Score      = top_vips
) %>%
mutate(Metabolite = recode(Metabolite,
"Hesp.galctoside" = "Hesp. galactoside",
"Tricin.5.O.glucoside" = "Tricin-5-O-glucoside"))
plot_b <- ggplot(vip_df, aes(x = Score, y = Metabolite)) +
geom_hline(yintercept = 1:nrow(vip_df), color = "gray90", linewidth = 0.5) +
geom_point(size = 4, color = "red") +
scale_x_continuous(labels = label_number(accuracy = 0.01)) +
scale_y_discrete(expand = expansion(mult = c(0.05, 0.05))) +
theme_bw() +
theme(
panel.grid.major.y = element_blank(),
panel.grid.minor   = element_blank(),
panel.border       = element_rect(color = "black", fill = NA, linewidth = 1),
axis.text          = element_text(color = "black", size = 11),
axis.title.x       = element_blank()
) +
labs(y = NULL)
plot_b

# Combine PLS-DA and VIP, then export as image
combined_final <- (plot_a + plot_b) +
